public class Statistiques
{
    public int CalculerSomme(int[] nombres)
    {
        if (nombres.Length == 0) throw new ArgumentException("Tableau vide");

        int somme = 0;
        for (int i = 0; i < nombres.Length; i++)
        {
            somme = somme + nombres[i];
        }
        return somme;
    }
}
Dans Tests/UnitTest1.cs :

